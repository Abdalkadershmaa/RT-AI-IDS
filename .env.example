# RT-AI-IDS environment configuration
#
# Copy this file to `.env` and fill in real values. Use `make bootstrap` to
# generate cryptographically random values for the *_KEY and *_PASSWORD entries.
#
# The application FAILS TO START if SECRET_KEY, JWT_SECRET_KEY, or
# ADMIN_PASSWORD are left at their placeholder values in production
# (ENVIRONMENT != "development").

# --- Runtime ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Auth (FAIL-FAST sentinels) ---
# Replace these. `make bootstrap` does it for you.
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# --- Datastores ---
DATABASE_URL=postgresql+psycopg2://ids:change-me-postgres@db:5432/ids
REDIS_URL=redis://:change-me-redis@redis:6379/0
POSTGRES_PASSWORD=change-me-postgres
REDIS_PASSWORD=change-me-redis

# --- Streams / queues ---
INGEST_STREAM=packet_ingest
FLOW_INFERENCE_STREAM=flow_inference
PREDICT_JOBS_STREAM=predict_jobs
BROKER_CONSUMER_GROUP=rt_ai_ids
PREDICT_RESULT_TTL_SECONDS=3600
# Approximate cap on Redis stream length (XADD MAXLEN ~). Bounds Redis
# memory under sustained load. 100k * ~1KB/msg ≈ 100MB per stream max.
BROKER_MAX_STREAM_LEN=100000
# Total attempts per consumed message before routing to <stream>_dlq.
BROKER_MAX_RETRIES=3

# --- Database connection pool ---
# Per-process pool sizing. Total connections per process = pool_size +
# max_overflow. Keep total headroom below Postgres max_connections.
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
# Postgres tuning when running via docker compose. Bumped above the default
# 100 so multiple replicas + readiness probes don't exhaust the slot pool.
POSTGRES_MAX_CONNECTIONS=200

# --- Inference ---
MODELS_DIR=models
ALLOW_FALLBACK_CLASSIFIER=false   # if true, missing model files boot a stub classifier
GUNICORN_WORKERS=2
# Metadata persisted with every alert so historical rows stay traceable to a
# specific model build after the live model is rolled forward. Set these in
# CI whenever you deploy a new model artefact.
MODEL_VERSION=unknown
MODEL_DATASET=CICIDS2017

# --- API hardening ---
# Brute-force guard on POST /api/v1/auth/token. Syntax is Flask-Limiter's
# (see https://flask-limiter.readthedocs.io/en/stable/#rate-limit-string-notation).
# Counter storage is shared across gunicorn workers via Redis when the API
# service has REDIS_URL configured.
AUTH_RATE_LIMIT=5 per minute

# --- Retention ---
# Delete attack_logs rows older than this many days when `flask retention-prune`
# runs. Set to 0 to disable pruning (keep every alert forever). Intended to be
# wired to a cron / systemd timer / Kubernetes CronJob; see docs/operations.md.
ATTACK_LOG_RETENTION_DAYS=90

# --- CORS (frontend) ---
# Comma-separated list of explicit origins allowed to call /api/*. Leave blank
# to disable cross-origin entirely (server-to-server only). Examples:
#   CORS_ALLOW_ORIGINS=http://localhost:5173,https://soc.example.com
# Wildcard (*) is intentionally not honored when credentials are involved.
CORS_ALLOW_ORIGINS=

# --- Capture (only used by `--profile capture`) ---
# Exact interface name to sniff. See docs/live-demo-setup.md for how to find
# this on Linux (`ip -br link`) or Windows (`Get-NetAdapter`).
# Examples:
#   Linux laptop hotspot:   CAPTURE_INTERFACE=wlan0
#   Linux USB Wi-Fi dongle: CAPTURE_INTERFACE=wlan1
#   Windows hotspot:        CAPTURE_INTERFACE=Wi-Fi
#   Windows hotspot virtual NIC: CAPTURE_INTERFACE=Local Area Connection* 12
CAPTURE_INTERFACE=eth0

# Optional Berkeley Packet Filter (BPF). Restricts which packets are captured
# at the kernel level. Leave empty to capture everything.
# Examples:
#   tcp                              # only TCP
#   tcp and not port 22              # exclude SSH noise during demo
#   tcp and (port 80 or port 443)    # web traffic only
CAPTURE_BPF_FILTER=

# Promiscuous mode — required to see traffic destined for OTHER hosts on the
# same L2 segment (i.e. attacker → victim flowing through your hotspot NIC).
# Default: true. Set to false ONLY if your network policy forbids promisc.
CAPTURE_PROMISCUOUS=true

# Alternative capture sources (mutually exclusive with CAPTURE_INTERFACE):
# CAPTURE_PCAP_FILE=/path/to/file.pcap   # offline replay
# CAPTURE_CMD="tcpdump -nni eth0 -l -j" # tcpdump JSON subprocess fallback
