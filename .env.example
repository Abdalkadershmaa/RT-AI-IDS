# RT-AI-IDS environment configuration
#
# Copy this file to `.env` and fill in real values. Use `make bootstrap` to
# generate cryptographically random values for the *_KEY and *_PASSWORD entries.
#
# The application FAILS TO START if SECRET_KEY, JWT_SECRET_KEY, or
# ADMIN_PASSWORD are left at their placeholder values in production
# (ENVIRONMENT != "development").

# --- Runtime ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- Auth (FAIL-FAST sentinels) ---
# Replace these. `make bootstrap` does it for you.
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# --- Datastores ---
DATABASE_URL=postgresql+psycopg2://ids:ids@db:5432/ids
REDIS_URL=redis://redis:6379/0

# --- Streams / queues ---
INGEST_STREAM=packet_ingest
FLOW_INFERENCE_STREAM=flow_inference
PREDICT_JOBS_STREAM=predict_jobs
BROKER_CONSUMER_GROUP=rt_ai_ids
PREDICT_RESULT_TTL_SECONDS=3600

# --- Inference ---
MODELS_DIR=models
ALLOW_FALLBACK_CLASSIFIER=false   # if true, missing model files boot a stub classifier
GUNICORN_WORKERS=2

# --- CORS (frontend) ---
# Comma-separated list of explicit origins allowed to call /api/*. Leave blank
# to disable cross-origin entirely (server-to-server only). Examples:
#   CORS_ALLOW_ORIGINS=http://localhost:5173,https://soc.example.com
# Wildcard (*) is intentionally not honored when credentials are involved.
CORS_ALLOW_ORIGINS=

# --- Capture (only used by `--profile capture`) ---
CAPTURE_INTERFACE=eth0
